{
  "manifest_version": 3,
  "name": "Meetup Blur Remover",
  "version": "1.0.0",
  "description": "Removes blur effects on Meetup pages.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.meetup.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}